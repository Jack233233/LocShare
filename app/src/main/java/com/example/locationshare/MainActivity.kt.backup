package com.example.locationshare

import android.Manifest
import android.content.pm.PackageManager
import android.os.Bundle
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity
import androidx.core.app.ActivityCompat
import androidx.core.content.ContextCompat
import androidx.lifecycle.lifecycleScope
import com.amap.api.location.AMapLocationClient
import com.amap.api.location.AMapLocationClientOption
import com.amap.api.maps.AMap
import com.amap.api.maps.CameraUpdateFactory
import com.amap.api.maps.model.LatLng
import com.amap.api.maps.model.Marker
import com.amap.api.maps.model.MarkerOptions
import com.example.locationshare.databinding.ActivityMainBinding
import io.socket.client.IO
import io.socket.client.Socket
import kotlinx.coroutines.launch
import org.json.JSONObject

class MainActivity : AppCompatActivity() {

    private lateinit var binding: ActivityMainBinding
    private lateinit var aMap: AMap
    private var locationClient: AMapLocationClient? = null
    private var socket: Socket? = null

    // 存储其他用户的标记
    private val userMarkers = mutableMapOf<String, Marker>()

    // 当前用户信息
    private var roomId: String = ""
    private var userName: String = ""
    private var userId: String = ""

    companion object {
        private const val LOCATION_PERMISSION_REQUEST = 1001
        private const val SERVER_URL = "http://47.109.86.151"
    }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        binding = ActivityMainBinding.inflate(layoutInflater)
        setContentView(binding.root)

        // 初始化地图
        binding.mapView.onCreate(savedInstanceState)
        initMap()

        // 检查权限
        checkLocationPermission()

        // 按钮事件
        binding.btnJoin.setOnClickListener {
            joinRoom()
        }

        binding.btnShareLocation.setOnClickListener {
            startSharingLocation()
        }
    }

    private fun initMap() {
        aMap = binding.mapView.map
        aMap.uiSettings.isZoomControlsEnabled = true
        aMap.uiSettings.isMyLocationButtonEnabled = true
    }

    private fun checkLocationPermission() {
        val permissions = arrayOf(
            Manifest.permission.ACCESS_FINE_LOCATION,
            Manifest.permission.ACCESS_COARSE_LOCATION
        )

        if (permissions.all {
            ContextCompat.checkSelfPermission(this, it) == PackageManager.PERMISSION_GRANTED
        }) {
            initLocation()
        } else {
            ActivityCompat.requestPermissions(this, permissions, LOCATION_PERMISSION_REQUEST)
        }
    }

    private fun initLocation() {
        try {
            locationClient = AMapLocationClient(applicationContext).apply {
                setLocationOption(AMapLocationClientOption().apply {
                    locationMode = AMapLocationClientOption.AMapLocationMode.Hight_Accuracy
                    interval = 3000
                    isNeedAddress = false
                })
            }
        } catch (e: Exception) {
            e.printStackTrace()
        }
    }

    private fun joinRoom() {
        roomId = binding.etRoomId.text.toString().trim()
        userName = binding.etUserName.text.toString().trim()

        if (roomId.isEmpty() || userName.isEmpty()) {
            Toast.makeText(this, "请输入房间号和你的名字", Toast.LENGTH_SHORT).show()
            return
        }

        userId = java.util.UUID.randomUUID().toString()

        connectSocket()
    }

    private fun connectSocket() {
        lifecycleScope.launch {
            try {
                socket = IO.socket(SERVER_URL).apply {
                    on(Socket.EVENT_CONNECT) {
                        runOnUiThread {
                            Toast.makeText(this@MainActivity, "已连接服务器", Toast.LENGTH_SHORT).show()
                            binding.btnJoin.isEnabled = false
                            binding.btnJoin.text = "已加入"
                        }

                        // 发送加入房间消息
                        val data = JSONObject().apply {
                            put("roomId", roomId)
                            put("userName", userName)
                            put("userId", userId)
                        }
                        emit("join", data)
                    }

                    on("location-update") { args ->
                        val data = args[0] as JSONObject
                        runOnUiThread {
                            updateUserLocation(data)
                        }
                    }

                    on("user-joined") { args ->
                        val data = args[0] as JSONObject
                        runOnUiThread {
                            Toast.makeText(
                                this@MainActivity,
                                "${data.optString("userName")} 加入了房间",
                                Toast.LENGTH_SHORT
                            ).show()
                        }
                    }

                    on("user-left") { args ->
                        val data = args[0] as JSONObject
                        runOnUiThread {
                            removeUserMarker(data.optString("userId"))
                        }
                    }

                    on("room-users") { args ->
                        val users = args[0] as JSONObject
                        runOnUiThread {
                            users.keys().forEach { key ->
                                updateUserLocation(users.getJSONObject(key))
                            }
                        }
                    }

                    on(Socket.EVENT_DISCONNECT) {
                        runOnUiThread {
                            Toast.makeText(this@MainActivity, "连接断开", Toast.LENGTH_SHORT).show()
                        }
                    }

                    connect()
                }
            } catch (e: Exception) {
                e.printStackTrace()
                runOnUiThread {
                    Toast.makeText(this@MainActivity, "连接失败: ${e.message}", Toast.LENGTH_LONG).show()
                }
            }
        }
    }

    private fun startSharingLocation() {
        if (socket == null || socket?.connected() != true) {
            Toast.makeText(this, "请先加入房间", Toast.LENGTH_SHORT).show()
            return
        }

        locationClient?.setLocationListener { location ->
            if (location.errorCode == 0) {
                val lat = location.latitude
                val lng = location.longitude

                // 移动地图到当前位置
                val latLng = LatLng(lat, lng)
                aMap.animateCamera(CameraUpdateFactory.newLatLngZoom(latLng, 16f))

                // 发送位置到服务器
                val data = JSONObject().apply {
                    put("lat", lat)
                    put("lng", lng)
                    put("accuracy", location.accuracy)
                    put("userName", userName)
                }
                socket?.emit("location-update", data)

                // 显示自己的位置
                binding.tvStatus.text = "正在共享位置: ${String.format("%.6f", lat)}, ${String.format("%.6f", lng)}"
            }
        }

        locationClient?.startLocation()
        binding.btnShareLocation.isEnabled = false
        binding.btnShareLocation.text = "共享中..."
    }

    private fun updateUserLocation(data: JSONObject) {
        val id = data.optString("userId")
        if (id == userId) return // 不显示自己

        val lat = data.optDouble("lat")
        val lng = data.optDouble("lng")
        val name = data.optString("userName", "未知用户")

        val latLng = LatLng(lat, lng)

        // 更新或创建标记
        val marker = userMarkers[id]
        if (marker != null) {
            marker.position = latLng
        } else {
            val newMarker = aMap.addMarker(MarkerOptions()
                .position(latLng)
                .title(name)
                .snippet("最后更新: ${System.currentTimeMillis()}")
            )
            userMarkers[id] = newMarker
        }
    }

    private fun removeUserMarker(userId: String) {
        userMarkers.remove(userId)?.remove()
    }

    override fun onRequestPermissionsResult(
        requestCode: Int,
        permissions: Array<out String>,
        grantResults: IntArray
    ) {
        super.onRequestPermissionsResult(requestCode, permissions, grantResults)
        if (requestCode == LOCATION_PERMISSION_REQUEST) {
            if (grantResults.all { it == PackageManager.PERMISSION_GRANTED }) {
                initLocation()
            } else {
                Toast.makeText(this, "需要定位权限才能共享位置", Toast.LENGTH_LONG).show()
            }
        }
    }

    override fun onResume() {
        super.onResume()
        binding.mapView.onResume()
    }

    override fun onPause() {
        super.onPause()
        binding.mapView.onPause()
    }

    override fun onSaveInstanceState(outState: Bundle) {
        super.onSaveInstanceState(outState)
        binding.mapView.onSaveInstanceState(outState)
    }

    override fun onDestroy() {
        super.onDestroy()
        locationClient?.stopLocation()
        locationClient?.onDestroy()
        socket?.disconnect()
        socket?.off()
        binding.mapView.onDestroy()
    }
}
