<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 高德地图（全屏） -->
    <com.amap.api.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 路线共享悬浮按钮（左上角） -->
    <TextView
        android:id="@+id/routeShareFab"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="16dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_route_share_fab"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:text="📍 行程共享中"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:visibility="gone"
        android:elevation="4dp" />

    <!-- 路线共享弹窗 -->
    <FrameLayout
        android:id="@+id/routeShareDialog"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="行程共享中"
                android:textColor="#2C3E50"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 路线名称 -->
            <TextView
                android:id="@+id/tvRouteName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="路线名称"
                android:textColor="#2C3E50"
                android:textSize="16sp" />

            <!-- 终点 -->
            <TextView
                android:id="@+id/tvRouteEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="终点：--"
                android:textColor="#666666"
                android:textSize="14sp" />

            <!-- 剩余距离 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvRemainingDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FF8A65"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="米"
                    android:textColor="#999999"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 共享给的好友 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_avatar_gradient" />

                <TextView
                    android:id="@+id/tvSharedWith"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="共享给：--"
                    android:textColor="#666666"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 停止按钮 -->
            <TextView
                android:id="@+id/btnStopRouteShare"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_btn_danger"
                android:gravity="center"
                android:text="停止共享"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- 关闭弹窗 -->
            <TextView
                android:id="@+id/btnCloseDialog"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="关闭"
                android:textColor="#999999"
                android:textSize="14sp" />

        </LinearLayout>
    </FrameLayout>

    <!-- 底部抽屉（使用 BottomSheetBehavior） -->
    <FrameLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:background="@drawable/bg_bottom_sheet_rounded"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="140dp"
        app:behavior_hideable="false"
        android:clipToOutline="true">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
