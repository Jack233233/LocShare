<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 基础主题 - 日间模式 -->
    <style name="Theme.Together" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- 主色 -->
        <item name="colorPrimary">@color/primary_orange</item>
        <item name="colorPrimaryDark">@color/primary_orange_dark</item>
        <item name="colorAccent">@color/secondary_teal</item>

        <!-- 背景 -->
        <item name="android:windowBackground">@color/bg_warm_white</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/bg_warm_white</item>

        <!-- 文字 -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- 全屏 -->
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">false</item>

        <!-- 动画 -->
        <item name="android:windowAnimationStyle">@style/WindowAnimation</item>
    </style>

    <!-- 沉浸式主题（地图页使用） -->
    <style name="Theme.Together.Immersive">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>
    </style>

    <!-- 深色主题 -->
    <style name="Theme.Together.Dark">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/text_on_dark</item>
        <item name="android:textColorSecondary">@color/text_hint</item>
    </style>

    <!-- 全屏主题（欢迎页使用） -->
    <style name="Theme.Together.Fullscreen" parent="Theme.Together">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@drawable/bg_welcome_gradient</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>
    </style>

    <!-- 窗口动画 -->
    <style name="WindowAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_in_up</item>
        <item name="android:windowExitAnimation">@anim/slide_out_down</item>
    </style>

    <!-- 圆形图片 -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>
